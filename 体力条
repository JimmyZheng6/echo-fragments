//======================
// Player Speed
//======================

const WALK_SPEED = 3;
const RUN_SPEED = 12;

// current space
let current_speed = WALK_SPEED;

//======================
// Player Status
//======================

const MAX_HP = 100;
let hp = 100;

const MAX_STAMINA = 100;
let stamina = 100;

//======================
// Highlight
