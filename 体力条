//======================
// Player Functions
//======================

function move_player() {

    const p = query_position(player);

    let x = p[0];
    let y = p[1];
    
    //======================
// Sprint
//======================

if (input_key_down("f") && stamina > 0) {

    current_speed = RUN_SPEED;

    stamina = stamina - 0.5;

} else {

    current_speed = WALK_SPEED;

    if (stamina < MAX_STAMINA) {

        stamina = stamina + 0.2;

    }

}

if (stamina < 0) {
    stamina = 0;
}

if (stamina > MAX_STAMINA) {
    stamina = MAX_STAMINA;
}

  if (input_key_down("w")) {
    y = y - current_speed;
}

if (input_key_down("s")) {
    y = y + current_speed;
}

if (input_key_down("a")) {
    x = x - current_speed;
}

if (input_key_down("d")) {
    x = x + current_speed;
}

    update_position(player, [x, y]);

    return [x, y];

}

function update_status_bars(x, y) {

    update_position(
        hp_back,
        [x, y - 34]
    );

    update_position(
        stamina_back,
        [x, y - 28]
    );

    update_position(
        hp_front,
        [x, y - 34]
    );

    update_position(
        stamina_front,
        [x, y - 28]
    );

    update_scale(
        hp_front,
        [
            hp / MAX_HP,
            1
        ]
    );

    update_scale(
        stamina_front,
        [
            stamina / MAX_STAMINA,
            1
        ]
    );

}

function select_slot() {

    if (input_key_down("1")) {
        selected_slot = 0;
    }

    if (input_key_down("2")) {
        selected_slot = 1;
    }

    if (input_key_down("3")) {
        selected_slot = 2;
    }

    if (input_key_down("4")) {
        selected_slot = 3;
    }

    if (input_key_down("5")) {
        selected_slot = 4;
    }

    update_inventory();

}

//======================
// World Item Functions
//======================

function pickup_items(x, y) {

    for (let i = 0; i < array_length(world_items); i = i + 1) {

        if (world_items[i] !== undefined) {

            const piece_pos =
                query_position(world_items[i][1]);

            const dx = x - piece_pos[0];
            const dy = y - piece_pos[1];

            if (dx * dx + dy * dy < 35 * 35 &&
                input_key_down("e")) {

                add_item(world_items[i][0]);

                update_position(
                    world_items[i][1],
                    [-1000, -1000]
                );

                world_items[i] = undefined;

            }

        }

    }

}

function update_pickup_text(x, y) {

    let show = false;

    for (let i = 0; i < array_length(world_items); i = i + 1) {

        if (world_items[i] !== undefined) {

            const piece_pos =
                query_position(world_items[i][1]);

            const dx = x - piece_pos[0];
            const dy = y - piece_pos[1];

            if (dx * dx + dy * dy < 35 * 35) {

                show = true;

            }

        }

    }

    if (show) {

        update_text(
            pickup_text,
            "Press E to Pick Up"
        );

    } else {

        update_text(
            pickup_text,
            ""
        );

    }

}

function highlight_items(x, y) {

    for (let i = 0; i < array_length(world_items); i = i + 1) {

        if (world_items[i] !== undefined) {

            const pos =
                query_position(world_items[i][1]);

            const dx = x - pos[0];
            const dy = y - pos[1];

            if (dx * dx + dy * dy < 80 * 80) {

                if (piece_scale[i] < 0.35) {
                    piece_scale[i] =
                        piece_scale[i] + 0.005;
                }

            } else {

                if (piece_scale[i] > 0.25) {
                    piece_scale[i] =
                        piece_scale[i] - 0.005;
                }

            }

           if (piece_scale[i] === undefined) {
    piece_scale[i] = 0.25;
}

if (piece_scale[i] === undefined) {
    piece_scale[i] = 0.25;
}

update_scale(
    world_items[i][1],
    [piece_scale[i], piece_scale[i]]
);

        }

    }

}

function drop_item(x, y) {

    if (input_key_down("q")) {

        const item = inventory[selected_slot];

        if (item !== "") {

            update_position(
    drop_pool[next_drop],
    [x + 40, y]
);

const new_index = array_length(world_items);

world_items[new_index] =
    [item, drop_pool[next_drop], false];

piece_scale[new_index] = 0.25;

//new drop
piece_scale[array_length(world_items) - 1] = 0.25;

remove_item(selected_slot);

            next_drop = next_drop + 1;

            if (next_drop >= array_length(drop_pool)) {
                next_drop = 0;
            }

        }

    }

}

