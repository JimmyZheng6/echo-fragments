//======================
// Inventory UI
//======================

const inventory_text =
update_position(
    create_text(""),
    [300,550]
);

const pickup_text =
update_position(
    create_text(""),
    [300,520]
);

function update_inventory() {

    update_text(
        inventory_text,

        (selected_slot === 0 ? ">" : " ") +
        "[1] " + inventory[0] +

        "  " +

        (selected_slot === 1 ? ">" : " ") +
        "[2] " + inventory[1] +

        "  " +

        (selected_slot === 2 ? ">" : " ") +
        "[3] " + inventory[2] +

        "  " +

        (selected_slot === 3 ? ">" : " ") +
        "[4] " + inventory[3] +

        "  " +

        (selected_slot === 4 ? ">" : " ") +
        "[5] " + inventory[4]
    );

    return undefined;
}

function add_item(item) {

    let added = false;

    for (let i = 0; i < 5; i = i + 1) {

        if (!added && inventory[i] === "") {

            inventory[i] = item;
            added = true;

        }

    }

    update_inventory();

    return added;
}

function remove_item(slot) {

    if (slot >= 0 && slot < 5) {
        inventory[slot] = "";
    }

    update_inventory();

    return undefined;
}

