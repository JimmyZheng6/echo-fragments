import {
    create_text,
    update_text,
    create_sprite,
    update_position,
    update_scale,
    query_position,
    input_key_down,
    update_loop,
    build_game
} from "arcade_2d";

//======================
// Inventory
//======================

const inventory = [
    "",
    "",
    "",
    "",
    ""
];

let selected_slot = 0;
//======================
// Inventory UI
//======================

const inventory_text =
update_position(
    create_text(""),
    [300,550]
);

function update_inventory() {

    update_text(
        inventory_text,

        (selected_slot === 0 ? ">" : " ") +
        "[1] " + inventory[0] +

        "  " +

        (selected_slot === 1 ? ">" : " ") +
        "[2] " + inventory[1] +

        "  " +

        (selected_slot === 2 ? ">" : " ") +
        "[3] " + inventory[2] +

        "  " +

        (selected_slot === 3 ? ">" : " ") +
        "[4] " + inventory[3] +

        "  " +

        (selected_slot === 4 ? ">" : " ") +
        "[5] " + inventory[4]
    );

    return undefined;
}

function add_item(item) {

    let added = false;

    for (let i = 0; i < 5; i = i + 1) {

        if (!added && inventory[i] === "") {

            inventory[i] = item;
            added = true;

        }

    }

    update_inventory();

    return added;
}

function remove_item(slot) {

    if (slot >= 0 && slot < 5) {
        inventory[slot] = "";
    }

    update_inventory();

    return undefined;
}

//======================
// Player
//======================

const player =
update_position(
    update_scale(
        create_sprite("avatars/beat/beat.happy.png"),
        [0.3,0.3]
    ),
    [300,300]
);

//======================
// Player Functions
//======================

function move_player() {

    const p = query_position(player);

    let x = p[0];
    let y = p[1];

    if (input_key_down("w")) {
        y = y - 3;
    }

    if (input_key_down("s")) {
        y = y + 3;
    }

    if (input_key_down("a")) {
        x = x - 3;
    }

    if (input_key_down("d")) {
        x = x + 3;
    }

    update_position(player, [x, y]);

    return [x, y];

}

function select_slot() {

    if (input_key_down("1")) {
        selected_slot = 0;
    }

    if (input_key_down("2")) {
        selected_slot = 1;
    }

    if (input_key_down("3")) {
        selected_slot = 2;
    }

    if (input_key_down("4")) {
        selected_slot = 3;
    }

    if (input_key_down("5")) {
        selected_slot = 4;
    }

    update_inventory();

}

//======================
// World Item Functions
//======================

function pickup_items(x, y) {

    for (let i = 0; i < array_length(world_items); i = i + 1) {

        if (world_items[i] !== undefined) {

            const piece_pos =
                query_position(world_items[i][1]);

            const dx = x - piece_pos[0];
            const dy = y - piece_pos[1];

            if (dx * dx + dy * dy < 35 * 35 &&
                input_key_down("e")) {

                add_item(world_items[i][0]);

                update_position(
                    world_items[i][1],
                    [-1000, -1000]
                );

                world_items[i] = undefined;

            }

        }

    }

}

function drop_item(x, y) {

    if (input_key_down("q")) {

        const item = inventory[selected_slot];

        if (item !== "") {

            update_position(
    drop_pool[next_drop],
    [x + 40, y]
);

world_items[array_length(world_items)] =
    [item, drop_pool[next_drop]];

remove_item(selected_slot);

            next_drop = next_drop + 1;

            if (next_drop >= array_length(drop_pool)) {
                next_drop = 0;
            }

        }

    }

}

//======================
// World Items
//======================

// 每个元素：
// [名字, sprite, 是否已拾取]

const piece1 =
update_position(
    update_scale(
        create_sprite("objects/cmr/splendall.png"),
        [0.25,0.25]
    ),
    [500,300]
);

const piece2 =
update_position(
    update_scale(
        create_sprite("objects/cmr/splendall.png"),
        [0.25,0.25]
    ),
    [220,180]
);

const piece3 =
update_position(
    update_scale(
        create_sprite("objects/cmr/splendall.png"),
        [0.25,0.25]
    ),
    [420,450]
);

const world_items = [

    ["Piece1", piece1, false],

    ["Piece2", piece2, false],

    ["Piece3", piece3, false]

];

//======================
// Drop Pool
//======================

const drop_pool = [

    update_position(
        update_scale(
            create_sprite("objects/cmr/splendall.png"),
            [0.25,0.25]
        ),
        [-1000,-1000]
    ),

    update_position(
        update_scale(
            create_sprite("objects/cmr/splendall.png"),
            [0.25,0.25]
        ),
        [-1000,-1000]
    ),

    update_position(
        update_scale(
            create_sprite("objects/cmr/splendall.png"),
            [0.25,0.25]
        ),
        [-1000,-1000]
    ),

    update_position(
        update_scale(
            create_sprite("objects/cmr/splendall.png"),
            [0.25,0.25]
        ),
        [-1000,-1000]
    ),

    update_position(
        update_scale(
            create_sprite("objects/cmr/splendall.png"),
            [0.25,0.25]
        ),
        [-1000,-1000]
    )

];

let next_drop = 0;

update_loop(game_state => {

   const player_pos = move_player();

const x = player_pos[0];
const y = player_pos[1];
    
    select_slot();

pickup_items(x, y);

drop_item(x, y);

});

//======================
// Test Inventory
//======================

update_inventory();

build_game();
