} from "arcade_2d";

const movement_dist=5;
const WIDTH=750;
const HEIGHT=800;
const TILE=25;
const PLAYER_SIZE=TILE*0.5;
const HALF=PLAYER_SIZE/2;

set_dimensions([WIDTH,HEIGHT]);

const ROWS=math_floor(750/TILE);
const COLS=math_floor(WIDTH/TILE);

const map=[];
let player_row=1;
let player_col=1;
let player=null;
const notes=[];
const note_objects=[];


//====================
// 初始化地图
//====================

for(let i=0;i<ROWS;i=i+1){
    map[i]=[];
    for(let j=0;j<COLS;j=j+1){
        map[i][j]=0;
    }
}

for(let i=0;i<ROWS;i=i+1){
    map[i][0]=1;
    map[i][COLS-1]=1;
}

for(let j=0;j<COLS;j=j+1){
    map[0][j]=1;
    map[ROWS-1][j]=1;
}


//====================
// 随机障碍
//====================

function blocked(r,c){

    if(r<=0||r>=ROWS-1||c<=0||c>=COLS-1){
        return false;
    }

    if(map[r][c]===1){
        return false;
    }

    let n=0;

    if(map[r-1][c]===1){n=n+1;}
    if(map[r+1][c]===1){n=n+1;}
    if(map[r][c-1]===1){n=n+1;}
    if(map[r][c+1]===1){n=n+1;}

    return n===4;
}


function generate_obstacles(){

    for(let i=1;i<ROWS-1;i=i+1){
        for(let j=1;j<COLS-1;j=j+1){
            map[i][j]=0;
        }
    }

    for(let i=1;i<ROWS-1;i=i+1){
        for(let j=1;j<COLS-1;j=j+1){

            if(i<=2&&j<=2){
                continue;
            }

            if(i>=ROWS-3&&j>=COLS-3){
                continue;
            }

            if(math_random()<0.2){

                map[i][j]=1;

                if(blocked(i-1,j)||
                   blocked(i+1,j)||
                   blocked(i,j-1)||
                   blocked(i,j+1)){
                    map[i][j]=0;
                }
            }
        }
    }

    map[player_row][player_col]=2;
    map[ROWS-2][COLS-2]=4;
}


//====================
// BFS
//====================

function map_ok(){

    const visited=[];

    for(let i=0;i<ROWS;i=i+1){
        visited[i]=[];
        for(let j=0;j<COLS;j=j+1){
            visited[i][j]=false;
        }
    }

    const queue=[];
    queue[0]=[player_row,player_col];
    visited[player_row][player_col]=true;

    let head=0;

    while(head<array_length(queue)){

        const p=queue[head];
        head=head+1;

        const r=p[0];
        const c=p[1];

        if(r===ROWS-2&&c===COLS-2){
            return true;
        }

        if(r>0&&!visited[r-1][c]&&map[r-1][c]!==1){
            visited[r-1][c]=true;
            queue[array_length(queue)]=[r-1,c];
        }

        if(r<ROWS-1&&!visited[r+1][c]&&map[r+1][c]!==1){
            visited[r+1][c]=true;
            queue[array_length(queue)]=[r+1,c];
        }

        if(c>0&&!visited[r][c-1]&&map[r][c-1]!==1){
            visited[r][c-1]=true;
            queue[array_length(queue)]=[r,c-1];
        }

        if(c<COLS-1&&!visited[r][c+1]&&map[r][c+1]!==1){
            visited[r][c+1]=true;
            queue[array_length(queue)]=[r,c+1];
        }
    }

    return false;
}


let tries=0;

while(true){

    generate_obstacles();

    if(map_ok()){
        break;
    }

    tries=tries+1;

    if(tries>100){
        break;
    }
}

//====================
// 生成音乐碎片
//====================

function spawn_note(){

    while(true){

        const r =
        1 + math_floor(
            math_random()*(ROWS-3)
        );

        const c =
        1 + math_floor(
            math_random()*(COLS-3)
        );


        let far=true;


        for(let i=0;i<array_length(notes);i=i+1){

    if(notes[i][0]!==-1){

        const old_r=notes[i][0];
        const old_c=notes[i][1];


        const dr=r-old_r;
        const dc=c-old_c;


        if(dr*dr+dc*dc<16){

            far=false;

        }

    }

}


        if(map[r][c]===0&&far){

            map[r][c]=3;
            
            const note_color=[math_floor(math_random()*255),
            math_floor(math_random()*255), 
            math_floor(math_random()*255),255];
            const note =update_position(update_color(update_scale(
            create_text("♪"),[2,2]),note_color),[c*TILE+TILE/2,r*TILE+TILE/2]);

            notes[array_length(notes)] = [r,c,note_color];

            note_objects[array_length(note_objects)]=note;


            break;
        }

    }

}
// 生成音符
for(let i=0;i<15;i=i+1){
    spawn_note();
}








for(let i=0;i<ROWS;i=i+1){

