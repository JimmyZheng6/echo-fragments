function update_inventory(){


    for(let i=0;i<8;i=i+1){


        const numbers=["[1] ","[2] ","[3] ","[4] ","[5] ","[6] ","[7] ","[8] "];
        let text=numbers[i];


        if(inventory[i]!==""){

            text=text+inventory[i][0];


            update_color(
                inventory_text[i],
                inventory[i][1]
            );

        }
        else{

            update_color(
                inventory_text[i],
                [255,255,255,255]
            );

        }


        if(selected_slot===i){

            text=">"+text;

        }


        update_text(
            inventory_text[i],
            text
        );

    }

}


//====================
// Inventory Functions
//====================

function add_item(item){

    let added=false;

    for(let i=0;i<8;i=i+1){

        if(!added&&inventory[i]===""){

            inventory[i]=item;
            added=true;

        }

    }

    update_inventory();

    return added;
}

function remove_item(slot){

    if(slot>=0&&slot<8){

        inventory[slot]="";

    }

    update_inventory();

}


function select_slot(){

    if(input_key_down("1")){
        selected_slot=0;
    }

    if(input_key_down("2")){
        selected_slot=1;
    }

    if(input_key_down("3")){
        selected_slot=2;
    }

    if(input_key_down("4")){
        selected_slot=3;
    }

    if(input_key_down("5")){
        selected_slot=4;
    }
    if(input_key_down("6")){
    selected_slot=5;
    }
    
    if(input_key_down("7")){
    selected_slot=6;
        
    }
    if(input_key_down("8")){
    selected_slot=7;
        
    }

}




