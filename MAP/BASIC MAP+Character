//====================
// 拾取提示
//====================

function update_note_text(x,y){

    let show=false;


    for(let i=0;i<array_length(notes);i=i+1){

        const r=notes[i][0];
        const c=notes[i][1];


        if(r!==-1){

            const nx=c*TILE+TILE/2;
            const ny=r*TILE+TILE/2;

            const dx=x-nx;
            const dy=y-ny;

            if(dx*dx+dy*dy<35*35){

                show=true;

            }
        }
    }

    if(show){
        update_text(pickup_text,"Press E to collect ♪");
    }
    else{
        update_text(pickup_text,"");
    }

}



//====================
// 拾取物品
//====================
function pickup_notes(x,y){

    for(let i=0;i<array_length(notes);i=i+1){

        const r=notes[i][0];
        const c=notes[i][1];

        if(r!==-1){

            const nx=c*TILE+TILE/2;
            const ny=r*TILE+TILE/2;

            const dx=x-nx;
            const dy=y-ny;


            if(dx*dx+dy*dy<50*50){

                if(input_key_down("e")){

                    const success=
                    add_item(["♪", notes[i][2]]);


                    if(success){
                        map[r][c]=0;

                        notes[i][0]=-1;
                        notes[i][1]=-1;


                        if(note_objects[i]!==undefined){

                            update_position(
                                note_objects[i],
                                [-1000,-1000]
                            );

                        }


                        update_inventory();
                        break;

                    }

                }

            }

        }

    }

}
//====================
// 丢弃物品
//====================

function drop_item(x,y){

    if(input_key_down("q")){

        const item=inventory[selected_slot];

        if(item!==""){

            remove_item(selected_slot);

        }

    }

}



//====================
// 撞墙检测
//====================

function can_move(pos){


    const left=math_floor((pos[0]-HALF)/TILE);


    const right=math_floor((pos[0]+HALF)/TILE);


    const top=math_floor((pos[1]-HALF)/TILE);

    const bottom=math_floor((pos[1]+HALF)/TILE);
    if(left<0||right<0||top<0||bottom<0||left>=COLS||right>=COLS||top>=ROWS||
   bottom>=ROWS){

    return false;

  }


    return map[top][left]!==1&&
           map[top][right]!==1&&
           map[bottom][left]!==1&&
           map[bottom][right]!==1;

}



//====================
// 主循环
//====================

update_loop(game_state=>{


    const pos=
    query_position(player);



    if(input_key_down("w")){

        pos[1]=pos[1]-movement_dist;

    }


    if(input_key_down("s")){

        pos[1]=pos[1]+movement_dist;

    }


    if(input_key_down("a")){

        pos[0]=pos[0]-movement_dist;

    }


    if(input_key_down("d")){

        pos[0]=pos[0]+movement_dist;

    }



    if(can_move(pos)){

        update_position(player,pos);
        player_row=math_floor(pos[1]/TILE);
        player_col=math_floor(pos[0]/TILE);

    }

    select_slot();

    update_note_text( pos[0],pos[1]);

    pickup_notes(pos[0],pos[1]);

    drop_item(pos[0],pos[1]);

    update_to_top(player);
    for(let i=0;i<array_length(note_objects);i=i+1){

        if(notes[i][0]!==-1){

            update_to_top(note_objects[i]);
        }
    }


});



update_inventory();


build_game();
